    "basicDetails": {
      "description": "You are starting a window installation and glazing business with nothing but your truck, a few basic tools, and your own two hands. Bootstrap from a first paying job to a regional window empire while lead drought, cash burn, and entrenched competitors erode every idle week.",
      "name": "The Clear View Window Co."
    },
    "customEvents": {
      "events": [
        {
          "image": "first-install",
          "scriptBody": "-- Fires once the company holds ground in two neighborhoods.\nON claimed >= 2\nTEXT The first two neighborhoods talk. A month of clean installs lands three referral quotes in one week.\nBUTTON Answer every call\nEFFECT resource:lead-pipeline +20\nEFFECT authority +4",
          "scriptFileName": "word-of-mouth.lua",
          "title": "Word of mouth"
        },
        {
          "image": "cracked-pane",
          "scriptBody": "-- The incumbents notice the new truck.\nON turn >= 45\nTEXT Pane & Simple undercuts you on a whole block of storm-window installs. The crew hears about it at the supply counter before you do.\nBUTTON Sharpen the next bid\nEFFECT pressure +8\nEFFECT morale -4",
          "scriptFileName": "rival-underbid.lua",
          "title": "Undercut on Storm Row"
        },
        {
          "image": "winter-boardup",
          "scriptBody": "-- Winter work: pays well, comes back every year.\nON season = winter-slowdown\nON turn >= 60\nTEXT A cold snap cracks panes across the county. Emergency board-up work pays double for a crew that answers the phone at night.\nBUTTON Roll the truck\nEFFECT resource:operating-cash +30\nEFFECT stamina +2\nREPEAT",
          "scriptFileName": "board-up-contract.lua",
          "title": "Cold-snap board-ups"
        },
        {
          "image": "cracked-pane",
          "scriptBody": "-- Mid-game escalation.\nON turn >= 150\nTEXT A big-box home center opens a window department off the interstate: glossy flyers, teaser pricing, subcontracted installers.\nBUTTON We out-craft them\nEFFECT pressure +10\nEFFECT morale -5",
          "scriptFileName": "big-box-outlet.lua",
          "title": "The big-box window aisle"
        },
        {
          "image": "contract-signing",
          "scriptBody": "-- Reward for a healthy balance sheet.\nON resource:operating-cash >= 120\nTEXT The glass supplier has watched your balance grow all season. He offers net-sixty terms and a pallet discount with a handshake.\nBUTTON Sign the terms\nEFFECT resource:glass-stock +25\nEFFECT patience +30",
          "scriptFileName": "net-sixty-terms.lua",
          "title": "Net-sixty terms"
        },
        {
          "image": "tailgate-huddle",
          "scriptBody": "-- The grind bites back once the company is worth raiding.\nON pressure >= 50\nON population >= 4\nTEXT A rival owner calls your best installer at home with a signing bonus and a newer truck.\nBUTTON Wish him well, mean it\nEFFECT population -1\nEFFECT morale -6",
          "scriptFileName": "poaching-call.lua",
          "title": "The poaching call"
        }
      ]
    },
